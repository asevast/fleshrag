# Пути для индексации (разделитель ; для Windows, : для Linux/Mac)
INDEX_PATHS=/mnt/d

# Провайдер моделей (cloud/local)
DEFAULT_PROVIDER=cloud

# Cloud provider (NeuralDeep)
NEURALDEEP_BASE_URL=https://api.neuraldeep.ru/v1
NEURALDEEP_API_KEY=sk-NSlYhFlLl6A_SEqLzkomTQ

# Cloud модели
CLOUD_LLM_MODEL=gpt-oss-120b
CLOUD_LLM_ECONOMY_MODEL=qwen3.6-35b-a3b
CLOUD_EMBED_MODEL=e5-large
CLOUD_EMBED_ALT_MODEL=bge-m3
CLOUD_RERANK_MODEL=bge-reranker

# Local модели
LOCAL_LLM_MODEL=qwen2.5:3b
LOCAL_EMBED_MODEL=multilingual-e5-large
LOCAL_RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Embed-service URL (для multilingual-e5-large)
# В Docker: http://embed-service:8001
# Локально: http://localhost:8001
EMBED_SERVICE_URL=http://embed-service:8001

# Ollama
OLLAMA_HOST=http://ollama:11434

# Qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# Redis
REDIS_URL=redis://redis:6379/0

# SQLite
DATABASE_URL=sqlite:////app/data/metadata.db

# Параметры чанкинга
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# Параметры поиска
TOP_K_SEARCH=20
TOP_K_RERANK=5

# Параметры LLM
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=1000
