# --- Provider mode ---
# cloud is used by default when NEURALDEEP_API_KEY is set.
DEFAULT_PROVIDER=cloud
NEURALDEEP_API_KEY=
NEURALDEEP_BASE_URL=https://api.neuraldeep.ru/v1

# --- Model defaults ---
LOCAL_LLM_MODEL=qwen2.5:3b
LOCAL_EMBED_MODEL=nomic-embed-text
CLOUD_LLM_MODEL=gpt-oss-120b
CLOUD_LLM_ECONOMY_MODEL=qwen3.6-35b-a3b
CLOUD_EMBED_MODEL=e5-large
CLOUD_EMBED_ALT_MODEL=bge-m3
CLOUD_RERANK_MODEL=bge-reranker

# --- Runtime tuning ---
CHUNK_SIZE=512
CHUNK_OVERLAP=64
TOP_K_SEARCH=20
TOP_K_RERANK=5
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=1000
CELERY_CONCURRENCY=2

# --- Storage / services ---
DATABASE_URL=sqlite:////app/data/metadata.db
QDRANT_HOST=qdrant
QDRANT_PORT=6333
REDIS_URL=redis://redis:6379/0
OLLAMA_HOST=http://ollama:11434

# --- Index mounting ---
# Host path to mount into containers. For a quick MVP run, point this at one folder.
# Windows example: INDEX_ROOT_HOST=./test_data
# Linux example:   INDEX_ROOT_HOST=/home/user/Documents
INDEX_ROOT_HOST=./test_data
INDEX_ROOT_CONTAINER=/mnt/indexed

# Paths inside the container that should be indexed.
# Usually keep this aligned with INDEX_ROOT_CONTAINER for the fastest setup.
INDEX_PATHS=/mnt/indexed
